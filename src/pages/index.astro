---
import Layout from "../layouts/Layout.astro";
import Divider from "../components/Divider.astro";
import SearchBar from "../components/SearchBar";
import SwiperGallery from "../components/SwiperGallery.astro";
import ImageCard from "../components/ImageCard.astro";

// Lugares imperdibles
const imperdibles = [
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/ZONA-ARQUELÓGICA.png",
    label: "Zona Arqueológica – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/SANTUARIO-DE-LA-VIRGEN-DE-LOS-REMEDIOS.png",
    label: "Santuario de la Virgen de los Remedios – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/PORTAL-GUERRERO.png",
    label: "Portal Guerrero – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/PARROQUIA-DE-SAN-PEDRO.png",
    label: "Parroquia de San Pedro – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/PARQUE-SORIA.png",
    label: "Parque Soria – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/IGLESIA-DE-SANTIAGO.png",
    label: "Iglesia de Santiago – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/IGLESIA-DE-SANTA-MARIA-XIXITLA.png",
    label: "Iglesia de Santa María Xixitla – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/COSME-DEL-RAZO.png",
    label: "Mercado Municipal Cosme del Razo – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/CONVENTO-DE-SAN-GABRIEL.png",
    label: "Convento de San Gabriel y Capilla Real – Cholula",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/CERRO-ZAPOTECAS.png",
    label: "Cerro del Zapotecas – Cholula",
  },
];

// Eventos
const eventos = [
  "https://visitcholula.mx/wp-content/uploads/2026/06/WhatsApp-Image-2026-06-16-at-7.14.18-PM-736x1024.jpeg",
  "https://visitcholula.mx/wp-content/uploads/2026/01/payasos-1024x1024.jpg",
  "https://visitcholula.mx/wp-content/uploads/2026/06/WhatsApp-Image-2026-06-19-at-7.36.55-PM-791x1024.jpeg",
];

// Galería Cholula corazón de México
const galeria = [
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/WhatsApp-Image-2025-07-04-at-20.47.49-1-scaled.jpeg",
    label: "Cholula Corazón de México",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/WhatsApp-Image-2025-07-04-at-20.47.49-2-scaled.jpeg",
    label: "Cholula Corazón de México",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/WhatsApp-Image-2025-07-04-at-20.47.49.jpeg",
    label: "Cholula Corazón de México",
  },
  {
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/WhatsApp-Image-2025-07-04-at-20.47.49-3-scaled.jpeg",
    label: "Cholula Corazón de México",
  },
];

// Visítanos – categorías
const visitanos = [
  {
    href: "/donde-hospedarse",
    label: "Hoteles",
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/hotel_tila_cholula_1-1024x1024-1.jpg",
    color: "var(--color-primary)",
  },
  {
    href: "/donde-comer",
    label: "Restaurantes – Bares",
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/Churreria-Las-Duyas_cholula_1-1024x1024-1.webp",
    color: "var(--color-accent)",
  },
  {
    href: "/que-hacer",
    label: "Qué Hacer",
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/Turiwheel_cholula_2-1024x1024-1.webp",
    color: "var(--color-secondary)",
  },
];

// Artesanías – mercados
const artesanias = [
  {
    href: "https://www.google.com/maps/place/Parque+Soria",
    label: "Parque Soria",
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/Artesanias-Parque-Soria_cholula.jpg",
    color: "var(--color-primary)",
    target: "_blank",
  },
  {
    href: "https://www.google.com/maps/place/Centro+San+Pedro+Cholula",
    label: "Zona Centro",
    img: "https://visitcholula.mx/wp-content/uploads/2025/11/Artesanias-Zona-Centro.jpg.webp",
    color: "var(--color-accent)",
    target: "_blank",
  },
];

import cholulaData from "../data/cholula.json";

// Items para la barra de búsqueda (Hoteles, Restaurantes, Qué hacer, Guías)
const searchItems = [
  ...(cholulaData.hoteles || []).map((item: any, i) => {
    const estrellasText = item.estrellas ? `${item.estrellas} estrellas` : "";
    return {
      id: i,
      label: item.nombre,
      category: "Hotel",
      href: "/donde-hospedarse",
      sublabel: "",
      searchKeywords: estrellasText,
      rating: item.estrellas || 0,
      horario: item.horario,
    };
  }),
  ...(cholulaData.restaurantes || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Restaurante",
    href: "/donde-comer",
    sublabel: [item.tipoComida, item.ambiente, item.caracteristicasEspeciales]
      .filter(Boolean)
      .join(" • "),
    searchKeywords: [
      item.clasificacion,
      item.dondeEsta,
      item.tipoComida,
      item.ambiente,
      item.caracteristicasEspeciales,
      item.idealPara,
      item.horario?.detalle,
    ]
      .filter(Boolean)
      .join(" "),
    horario: item.horario,
  })),
  ...(cholulaData.queHacer || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Destino",
    href: "/que-hacer",
    sublabel: item.tipo || "",
    horario: item.horario,
  })),
  ...(cholulaData.guiasTuristicos || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Guia",
    href: "/guias-turisticos",
    sublabel: item.paginaFacebook || "",
    horario: item.horario,
  })),
];
---

<Layout
  title="Inicio"
  description="Descubre la magia de Cholula, el corazón de México"
>
  <!-- ══════════════════════════════
       HERO — Video cover full screen
       ══════════════════════════════ -->
  <section class="hero" id="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="/salida.avif" type="video/av1" />
      <source src="/video.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="hero-search-wrapper">
        <SearchBar
          client:load
          items={searchItems}
          placeholder="Busca experiencias increíbles..."
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       BIENVENIDO A CHOLULA
       ══════════════════════════════ -->
  <section class="section-bienvenido" id="bienvenido">
    <div class="container">
      <h2 class="section-label">BIENVENIDO A CHOLULA</h2>
      <Divider />

      <div class="bienvenido-body">
        <div class="bienvenido-text">
          <p>
            San Pedro Cholula combina la historia viva de un pueblo prehispánico
            con la riqueza arquitectónica y cultural de las construcciones
            coloniales. Su fundación data del año 500 a.c., lo que la convierte
            en una de las poblaciones vivas más antiguas de América. Cholula te
            llevará a una experiencia como ninguna otra gracias al impresionante
            encuentro entre culturas que existe.
          </p>
          <p>
            Desde la Pirámide más grande en base del mundo pasando por los
            templos construidos en la época colonial, hasta las edificaciones
            que marcan la llegada de la época moderna.
          </p>
        </div>

        <div class="bienvenido-logos">
          <img
            src="https://visitcholula.mx/wp-content/uploads/2025/11/latido-de-puebla-FINAL-1024x552.png"
            alt="Cholula – El latido de Puebla"
            class="logo-partner"
            loading="lazy"
          />
          <img
            src="https://visitcholula.mx/wp-content/uploads/2025/11/separador-02.png"
            class="logo-separator"
            alt=""
            aria-hidden="true"
          />
          <img
            src="https://visitcholula.mx/wp-content/uploads/2025/11/Main-Tagline_Color_RGB_ES_PUE_250623-1024x290.png"
            alt="Puebla – El latido de México"
            class="logo-partner"
            loading="lazy"
          />
          <img
            src="https://visitcholula.mx/wp-content/uploads/2025/11/separador-02.png"
            class="logo-separator"
            alt=""
            aria-hidden="true"
          />
          <img
            src="https://visitcholula.mx/wp-content/uploads/2026/04/Untitled-design-3-Photoroom-e1775961036414-1024x888.png"
            alt="Cholula Pueblo Mágico"
            class="logo-partner logo-partner--small"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       LOS IMPERDIBLES — Carrusel
       ══════════════════════════════ -->
  <section class="section-imperdibles" id="imperdibles">
    <div class="container">
      <h2 class="section-label section-label--amarillo">LOS IMPERDIBLES</h2>
      <Divider />
    </div>
    <SwiperGallery id="imperdibles" items={imperdibles} isImperdible={true} />
  </section>

  <!-- ══════════════════════════════
       EVENTOS — Carrusel 2 columnas
       ══════════════════════════════ -->
  <section class="section-eventos" id="eventos">
    <div class="container">
      <h2 class="section-label section-label--turquesa">EVENTOS</h2>
      <Divider />
    </div>
    <SwiperGallery
      id="eventos"
      items={eventos.map((e) => ({ img: e }))}
      isEvento={true}
    />
  </section>

  <!-- ══════════════════════════════
       VISÍTANOS — Categorías
       ══════════════════════════════ -->
  <section class="section-visitanos" id="visitanos">
    <div class="container">
      <h2 class="section-label section-label--coral">VISÍTANOS</h2>
      <Divider />
    </div>
    <div class="visitanos-grid">
      {
        visitanos.map((v) => (
          <ImageCard
            href={v.href}
            img={v.img}
            label={v.label}
            color={v.color}
          />
        ))
      }
    </div>
  </section>

  <!-- ══════════════════════════════
       MAPA + CROQUIS
       ══════════════════════════════ -->
  <section class="section-mapa" id="mapa">
    <div class="container mapa-grid">
      <div class="mapa-embed">
        <iframe
          src="https://www.google.com/maps/d/embed?mid=1y8P9LnOP4uYJdVrJxk3YZyxxSxrpdcM&ehbc=2E312F"
          width="100%"
          height="100%"
          loading="lazy"
          title="Mapa de Cholula"></iframe>
      </div>
      <div class="mapa-croquis">
        <img
          src="https://visitcholula.mx/wp-content/uploads/2025/11/CROQUIS_MOVIL.jpg-576x1024.webp"
          alt="Croquis turístico de Cholula"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       CHOLULA EL CORAZÓN MÁGICO
       ══════════════════════════════ -->
  <section class="section-galeria" id="galeria">
    <div class="container">
      <h2 class="section-label section-label--turquesa">
        CHOLULA, EL CORAZÓN MÁGICO DE MÉXICO
      </h2>
      <Divider />
    </div>
    <SwiperGallery id="galeria" items={galeria} />
  </section>

  <!-- ══════════════════════════════
       ARTESANÍAS
       ══════════════════════════════ -->
  <section class="section-artesanias" id="artesanias">
    <div class="container">
      <h2 class="section-label section-label--coral">ARTESANÍAS</h2>
      <Divider />
    </div>
    <div class="artesanias-grid">
      {
        artesanias.map((a) => (
          <ImageCard
            href={a.href}
            img={a.img!}
            label={a.label}
            color={a.color!}
            target={a.target}
          />
        ))
      }
    </div>
  </section>
</Layout>

<style>
  /* ══════════════════════════
     HERO
     ══════════════════════════ */
  .hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    z-index: 10; /* Added to ensure dropdown overlaps next section */
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.1) 40%,
      rgba(0, 0, 0, 0.1) 60%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }
  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end; /* Align to the bottom */
    padding: 0 1rem; /* Removed bottom padding */
    width: 100%;
  }

  .hero-title-big {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 900;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem 0;
    text-align: center;
    line-height: 1;
    font-family: "Outfit", "Roboto", sans-serif;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
  }

  .hero-search-wrapper {
    width: 100%;
    max-width: 850px; /* Increased max width */
    margin: 0 auto;
    transform: translateY(
      50%
    ); /* Posiciona la mitad sobre el hero y la mitad sobre la sección inferior */
  }

  .hero-subtitle {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #dfdfdf;
    margin: 2.5rem 0 0 0;
    text-align: center;
    font-family: "Outfit", "Roboto", sans-serif;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  /* ══════════════════════════════════════════════
     RESET DARK THEME — sections below hero use the
     global-opt.css (WordPress) design system:
     white background · #808285 text · system fonts
     ══════════════════════════════════════════════ */
  .section-bienvenido,
  .section-imperdibles,
  .section-eventos,
  .section-visitanos,
  .section-mapa,
  .section-galeria,
  .section-artesanias,
  .section-redes {
    padding: 4.5rem 0;
    text-align: center;
    background-color: #f7f7f7;
    color: #808285;
  }

  /* Alternate background for rhythm */
  .section-imperdibles,
  .section-visitanos,
  .section-galeria,
  .section-redes {
    background-color: #f9f9f9;
  }

  .section-redes {
    padding-top: 6rem;
    padding-bottom: 0;
  }

  /* Section headings — match WP bold uppercase style */
  .section-label {
    text-align: center;
    font-family: "Roboto", sans-serif;
    font-size: 2vw;
    font-weight: 700;
    color: #555;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .section-label {
      font-size: 1.75rem;
    }
  }

  .section-label.section-label--coral {
    color: var(--color-primary);
  }
  .section-label.section-label--turquesa {
    color: var(--color-secondary);
  }
  .section-label.section-label--amarillo {
    color: var(--color-accent);
  }

  /* Decorative divider is now managed by the <Divider /> component */

  /* ══════════════════════════
     BIENVENIDO
     ══════════════════════════ */
  .bienvenido-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
    max-width: 1600px;
    margin: 0 auto;
  }
  .bienvenido-text {
    width: 85%;
  }
  .bienvenido-text p {
    color: #808285;
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 1.2rem;
  }
  .bienvenido-logos {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 80%;
  }
  .logo-partner {
    max-width: 500px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .logo-partner--small {
    max-width: 352px;
  }
  @media (max-width: 768px) {
    .logo-partner {
      width: 50%;
    }
  }
  .logo-separator {
    height: 122px;
    width: auto;
    display: none; /* hidden on mobile */
  }
  @media (min-width: 900px) {
    .bienvenido-logos {
      flex-direction: row;
      justify-content: space-evenly;
      gap: 1.5rem;
    }
    .logo-separator {
      display: block;
    }
  }

  /* ══════════════════════════
     VISÍTANOS
     ══════════════════════════ */
  .visitanos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin: 3rem auto 0;
    width: 80%;
    max-width: 1600px;
  }
  @media (max-width: 768px) {
    .visitanos-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ══════════════════════════
     MAPA
     ══════════════════════════ */
  .mapa-embed iframe {
    border: 0;
    border-radius: 12px;
    min-height: 500px;
  }
  .mapa-croquis img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .mapa-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 2rem;
    align-items: stretch;
    width: 80%;
    max-width: 1600px;
    margin: 0 auto;
    max-height: 915px;
  }
  @media (max-width: 768px) {
    .mapa-grid {
      grid-template-columns: 1fr;
    }
    .mapa-croquis {
      display: none;
    }
  }

  /* ══════════════════════════
     ARTESANÍAS
     ══════════════════════════ */
  .artesanias-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin: 3rem auto 0;
    width: 80%;
    max-width: 1600px;
  }
  @media (max-width: 768px) {
    .artesanias-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
