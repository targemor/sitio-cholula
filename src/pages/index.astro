---
import Layout from "../layouts/Layout.astro";
import SearchBar from "../components/SearchBar";
import SwiperGallery from "../components/SwiperGallery.astro";
import ImageCard from "../components/ImageCard.astro";
import ItinerarioTabs from "../components/ItinerarioTabs.astro";
import itinerarioData from "../data/itinerario.json";
import "../styles/index.css";

// Lugares imperdibles
const imperdibles = [
  {
    img: "/home/ZONA-ARQUELÓGICA.webp",
    label: "Zona Arqueológica – Cholula",
  },
  {
    img: "/home/SANTUARIO-DE-LA-VIRGEN-DE-LOS-REMEDIOS.webp",
    label: "Santuario de la Virgen de los Remedios – Cholula",
  },
  {
    img: "/home/PORTAL-GUERRERO.webp",
    label: "Portal Guerrero – Cholula",
  },
  {
    img: "/home/PARROQUIA-DE-SAN-PEDRO.webp",
    label: "Parroquia de San Pedro – Cholula",
  },
  {
    img: "/home/PARQUE-SORIA.webp",
    label: "Parque Soria – Cholula",
  },
  {
    img: "/home/IGLESIA-DE-SANTIAGO.webp",
    label: "Iglesia de Santiago – Cholula",
  },
  {
    img: "/home/IGLESIA-DE-SANTA-MARIA-XIXITLA.webp",
    label: "Iglesia de Santa María Xixitla – Cholula",
  },
  {
    img: "/home/COSME-DEL-RAZO.webp",
    label: "Mercado Municipal Cosme del Razo – Cholula",
  },
  {
    img: "/home/CONVENTO-DE-SAN-GABRIEL.webp",
    label: "Convento de San Gabriel y Capilla Real – Cholula",
  },
  {
    img: "/home/CERRO-ZAPOTECAS.webp",
    label: "Cerro del Zapotecas – Cholula",
  },
];

// Eventos
const eventos = [
  "https://visitcholula.mx/wp-content/uploads/2026/07/WhatsApp-Image-2026-07-03-at-6.57.58-PM-662x1024.jpeg",
  "https://visitcholula.mx/wp-content/uploads/2026/01/payasos-1024x1024.jpg",
  "https://visitcholula.mx/wp-content/uploads/2026/06/WhatsApp-Image-2026-06-26-at-10.35.06-AM-774x1024.jpeg",
];

// Galería Cholula corazón de México
const galeria = [
  {
    img: "/home/WhatsApp-Image-2025-07-04-at-20.47.49-1-scaled.webp",
    label: "Cholula Corazón de México",
  },
  {
    img: "/home/WhatsApp-Image-2025-07-04-at-20.47.49-2-scaled.webp",
    label: "Cholula Corazón de México",
  },
  {
    img: "/home/WhatsApp-Image-2025-07-04-at-20.47.49.webp",
    label: "Cholula Corazón de México",
  },
  {
    img: "/home/WhatsApp-Image-2025-07-04-at-20.47.49-3-scaled.webp",
    label: "Cholula Corazón de México",
  },
];

// Visítanos – categorías
const visitanos = [
  {
    href: "/donde-hospedarse",
    label: "Hoteles",
    img: "/home/hotel_tila_cholula_1-1024x1024-1.webp",
    color: "var(--color-primary)",
  },
  {
    href: "/donde-comer",
    label: "Restaurantes – Bares",
    img: "/home/Churreria-Las-Duyas_cholula_1-1024x1024-1.webp",
    color: "var(--color-accent)",
  },
  {
    href: "/que-hacer",
    label: "Qué Hacer",
    img: "/home/Turiwheel_cholula_2-1024x1024-1.webp",
    color: "var(--color-secondary)",
  },
];

// Artesanías – mercados
const artesanias = [
  {
    href: "https://www.google.com/maps/place/Parque+Soria",
    label: "Parque Soria",
    img: "/home/Artesanias-Parque-Soria_cholula.webp",
    color: "var(--color-primary)",
    target: "_blank",
  },
  {
    href: "https://www.google.com/maps/place/Centro+San+Pedro+Cholula",
    label: "Zona Centro",
    img: "/home/Artesanias-Zona-Centro.jpg.webp",
    color: "var(--color-accent)",
    target: "_blank",
  },
];

import cholulaData from "../data/cholula.json";

// Items para la barra de búsqueda (Hoteles, Restaurantes, Qué hacer, Guías)
const searchItems = [
  ...(cholulaData.hoteles || []).map((item: any, i) => {
    const estrellasText = item.estrellas ? `${item.estrellas} estrellas` : "";
    return {
      id: i,
      label: item.nombre,
      category: "Hotel",
      href: "/donde-hospedarse",
      sublabel: "",
      searchKeywords: [
        estrellasText,
        item.zona,
        item.distanciaGranPiramide,
        item.categoriaPrecio,
        item.aceptaMascotas,
        item.tieneAlberca,
        item.tieneSpa,
        item.terraza,
        item.recepcion24h,
        item.categoria,
        item.amenidades,
        item.precioNocheMxn,
        item.tamanioCategoria,
        item.perfilIdeal,
      ]
        .filter(Boolean)
        .join(" "),
      rating: item.estrellas || 0,
      horario: item.horario,
    };
  }),
  ...(cholulaData.restaurantes || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Restaurante",
    href: "/donde-comer",
    sublabel: [item.tipoComida, item.ambiente, item.caracteristicasEspeciales]
      .filter(Boolean)
      .join(" • "),
    searchKeywords: [
      item.clasificacion,
      item.dondeEsta,
      item.tipoComida,
      item.ambiente,
      item.caracteristicasEspeciales,
      item.idealPara,
      item.horario?.detalle,
      item.zona,
      item.categoriaPrecio,
      item.petFriendly,
      item.musicaEnVivo,
      item.precioPpMxn,
      item.reservacionRecomendada,
      item.ocasionIdeal,
      item.perfilIdeal,
      item.etiquetasChatbot,
      item.espacioFisico,
    ]
      .filter(Boolean)
      .join(" "),
    horario: item.horario,
  })),
  ...(cholulaData.queHacer || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Destino",
    href: "/que-hacer",
    sublabel: item.tipo || "",
    horario: item.horario,
  })),
  ...(cholulaData.guiasTuristicos || []).map((item: any, i) => ({
    id: i,
    label: item.nombre,
    category: "Guia",
    href: "/guias-turisticos",
    sublabel: item.paginaFacebook || "",
    horario: item.horario,
  })),
];
---

<Layout
  title="Inicio"
  description="Descubre la magia de Cholula, el corazón de México"
>
  <!-- ══════════════════════════════
       HERO — Video cover full screen
       ══════════════════════════════ -->
  <section class="hero" id="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
      fetchpriority="high"
    >
      <source src="/salida.avif" type="video/av1" fetchpriority="high" />
      <source src="/video.mp4" type="video/mp4" fetchpriority="high" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="hero-search-wrapper">
        <SearchBar
          client:load
          items={searchItems}
          placeholder="¿Qué te gustaría hacer hoy en San Pedro Cholula?"
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       BIENVENIDO A CHOLULA
       ══════════════════════════════ -->
  <section class="section-bienvenido" id="bienvenido">
    <div class="container bienvenido-container">
      <div class="bienvenido-kicker">San Pedro Cholula, Puebla</div>
      <div class="bienvenido-lead">
        Imagina una ciudad donde una iglesia del siglo XVI fue construida encima
        de la pirámide más grande del mundo.
      </div>
      <div class="bienvenido-stats">
        <div class="bienvenido-stat">
          <div class="bienvenido-stat-num">
            2,500<span class="bienvenido-stat-unit"> años</span>
          </div>
          <div class="bienvenido-stat-title">
            La ciudad viva más antigua del continente
          </div>
          <div class="bienvenido-stat-desc">
            Habitada sin parar desde el 500 a.C. — <strong
              >nunca abandonada</strong
            >
          </div>
        </div>
        <div class="bienvenido-stat">
          <div class="bienvenido-stat-num">+1M</div>
          <div class="bienvenido-stat-title">Visitantes al año</div>
          <div class="bienvenido-stat-desc">
            El Pueblo Mágico más visitado de Puebla — según DATATUR 2025
          </div>
        </div>
        <div class="bienvenido-stat">
          <div class="bienvenido-stat-num">
            500<span class="bienvenido-stat-unit"> años</span>
          </div>
          <div class="bienvenido-stat-title">
            El trueque más antiguo de América
          </div>
          <div class="bienvenido-stat-desc">
            <strong>Patrimonio Cultural Intangible de Puebla</strong> — cada septiembre,
            miles llegan a intercambiar artesanías y cosechas sin un peso de por medio
          </div>
        </div>
      </div>
    </div>

    <!-- Pirámide Mamona -->
    <section
      class="section-piramide"
      style="background-image: url('/home/piramide_mamona.webp');"
    >
      <div class="piramide-overlay"></div>
      <div class="piramide-content container">
        <h2 class="piramide-title">
          Tenemos la pirámide con la base <span class="piramide-title-highlight"
            >más grande del mundo</span
          >
        </h2>
        <p class="piramide-subtitle">
          Una iglesia en la cima, una pirámide bajo tus pies y el Popocatépetl
          de testigo.
        </p>
        <div class="piramide-actions">
          <a href="#itinerarios" class="piramide-btn-primary"
            >Planea tu visita</a
          >
          <a href="#imperdibles" class="piramide-btn-secondary"
            >Ver los imperdibles →</a
          >
        </div>
      </div>
    </section>

    <!-- Logos institucionales 
    <div class="bienvenido-logos">
      <img
        src="home/cholula lo tiene todo_logo.webp"
        alt="Cholula – El latido de Puebla"
        class="logo-partner"
        loading="lazy"
      />
      <div class="logo-separator" aria-hidden="true"></div>
      <img
        src="home/cholula_pueblo_magico.webp"
        alt="Cholula Pueblo Mágico"
        class="logo-partner logo-partner--small"
        loading="lazy"
      />
      <div class="logo-separator" aria-hidden="true"></div>
      <img
        src="home/logo_puebla.webp"
        alt="Puebla – El latido de México"
        class="logo-partner"
        loading="lazy"
      />
    </div>
    -->
  </section>

  <!-- ══════════════════════════════
       LOS IMPERDIBLES — Carrusel
       ══════════════════════════════ -->
  <section class="section-imperdibles" id="imperdibles">
    <div class="container">
      <h2 class="section-label section-label--amarillo">LOS IMPERDIBLES</h2>
    </div>
    <SwiperGallery id="imperdibles" items={imperdibles} isImperdible={true} />
  </section>

  <!-- ══════════════════════════════
       ITINERARIOS
       ══════════════════════════════ -->
  <section
    class="section-itinerarios"
    id="itinerarios"
    style="padding: 4.5rem 0; background-color: #f9f9f9;"
  >
    <div class="container">
      <h2 class="section-label section-label--coral">INSPÍRATE</h2>
    </div>

    <div style="margin-top: 3rem;">
      <ItinerarioTabs itinerarios={itinerarioData.itinerarios} />
    </div>
  </section>

  <!-- ══════════════════════════════
       MAPA + CROQUIS
       ══════════════════════════════ -->
  <section class="section-mapa" id="mapa">
    <div class="container mapa-grid">
      <div class="mapa-embed">
        <iframe
          src="https://www.google.com/maps/d/embed?mid=1y8P9LnOP4uYJdVrJxk3YZyxxSxrpdcM&ehbc=2E312F"
          width="100%"
          height="100%"
          loading="lazy"
          title="Mapa de Cholula"></iframe>
      </div>
      <div class="mapa-croquis">
        <img
          src="/home/CROQUIS_MOVIL.webp"
          alt="Croquis turístico de Cholula"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       EVENTOS — Carrusel 2 columnas
       ══════════════════════════════ -->
  <section class="section-eventos" id="eventos">
    <div class="container">
      <h2 class="section-label section-label--turquesa">EVENTOS</h2>
    </div>
    <SwiperGallery
      id="eventos"
      items={eventos.map((e) => ({ img: e }))}
      isEvento={true}
    />
  </section>

  <!-- ══════════════════════════════
       VISÍTANOS — Categorías
       ══════════════════════════════ -->
  <section class="section-visitanos" id="visitanos">
    <div class="container">
      <h2 class="section-label section-label--coral">VISÍTANOS</h2>
    </div>
    <div class="visitanos-grid">
      {
        visitanos.map((v) => (
          <ImageCard
            href={v.href}
            img={v.img}
            label={v.label}
            color={v.color}
          />
        ))
      }
    </div>
  </section>

  <!-- ══════════════════════════════
       CHOLULA EL CORAZÓN MÁGICO
       ══════════════════════════════ -->
  <section class="section-galeria" id="galeria">
    <div class="container">
      <h2 class="section-label section-label--turquesa">
        CHOLULA, EL CORAZÓN MÁGICO DE MÉXICO
      </h2>
    </div>
    <SwiperGallery id="galeria" items={galeria} isImperdible={true} />
  </section>

  <!-- ══════════════════════════════
       ARTESANÍAS
       ══════════════════════════════ -->
  <section class="section-artesanias" id="artesanias">
    <div class="container">
      <h2 class="section-label section-label--coral">ARTESANÍAS</h2>
    </div>
    <div class="artesanias-grid">
      {
        artesanias.map((a) => (
          <ImageCard
            href={a.href}
            img={a.img!}
            label={a.label}
            color={a.color!}
            target={a.target}
          />
        ))
      }
    </div>
  </section>
</Layout>
