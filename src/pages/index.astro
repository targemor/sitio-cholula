          target="_blank"
          aria-label="Instagram"
          class="social-icon-link"
        >
          <svg viewBox="0 0 448 512" width="56" height="56" aria-hidden="true">
            <defs>
              <linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#fdf497"></stop>
