---
import Layout from "../layouts/Layout.astro";
import Divider from "../components/Divider.astro";
import BusinessCard from "../components/BusinessCard.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import cholulaData from "../data/cholula.json";
import "../styles/slug.css";

export async function getStaticPaths() {
  return [
    {
      params: { slug: "donde-hospedarse" },
      props: {
        title: "DÓNDE HOSPEDARSE",
        color: "var(--color-primary)",
        data: cholulaData.hoteles,
      },
    },
    {
      params: { slug: "donde-comer" },
      props: {
        title: "DÓNDE COMER",
        color: "var(--color-accent)",
        data: cholulaData.restaurantes,
      },
    },
    {
      params: { slug: "que-hacer" },
      props: {
        title: "QUÉ HACER",
        color: "var(--color-secondary)",
        data: cholulaData.queHacer,
      },
    },
    {
      params: { slug: "guias-turisticos" },
      props: {
        title: "GUÍAS TURÍSTICOS",
        color: "#22c55e",
        data: cholulaData.guiasTuristicos,
        description:
          "GUÍAS CERTIFICADOS POR SECTUR — Descubre Cholula de una manera más personalizada junto a guías certificados que adaptan la experiencia a tus intereses y te ayudan a comprender la historia, tradiciones y patrimonio de la ciudad más allá de una visita convencional.",
      },
    },
  ];
}

const { title, color, data, description } = Astro.props;

const isRestaurantes = title === "DÓNDE COMER";
const clasificaciones = isRestaurantes
  ? (Array.from(
      new Set(data.map((item: any) => item.clasificacion).filter(Boolean)),
    ) as string[])
  : [];

const FALLBACK_IMG =
  "https://images.unsplash.com/photo-1605335191599-4458d98e1690?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80";
---

<Layout title={title}>
  <!-- Hero -->
  <section class="hero" id="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="/salida.avif" type="video/av1" />
      <source src="/video.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>
  </section>

  <!-- Sección con header fijo + grid scrolleable -->
  <section class="section-categoria">
    <div class="section-inner">
      <!-- Header fijo: título + divider + filtro -->
      <div class="section-header">
        <h2 class="section-label" style={`--section-color: ${color};`}>
          {title}
        </h2>
        <Divider />
        {description && <p class="section-description">{description}</p>}
        {
          isRestaurantes && clasificaciones.length > 0 && (
            <div class="filter-container">
              <CategoryFilter options={clasificaciones} />
            </div>
          )
        }
      </div>

      <!-- Área scrolleable con las tarjetas -->
      <div class="grid-scroll-area">
        <div class="business-grid">
          {
            data.map((item: any, index: number) => (
              <BusinessCard
                id={`item-${index}`}
                title={item.nombre}
                images={
                  item.imagenes && item.imagenes.length > 0
                    ? item.imagenes
                    : [FALLBACK_IMG]
                }
                address={item.direccion || undefined}
                mapsUrl={item.googleMaps || undefined}
                phone={item.telefono || undefined}
                whatsapp={item.whatsapp || undefined}
                sitioWeb={item.sitioWeb || undefined}
                telefonoAlt={item.telefonoAlt || undefined}
                tipoTelefono={item.tipoTelefono || undefined}
                instagram={item.social?.instagram || undefined}
                facebook={item.social?.facebook || undefined}
                tiktok={item.social?.tiktok || undefined}
                description={item.descripcion || undefined}
                clasificacion={item.clasificacion || undefined}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const params = new URLSearchParams(window.location.search);
    const searchId = params.get("id");
    const hash = window.location.hash;

    let targetCard: HTMLElement | null = null;

    if (searchId !== null) {
      targetCard = document.getElementById(`item-${searchId}`);
    } else if (hash && hash.startsWith("#item-")) {
      targetCard = document.getElementById(hash.substring(1));
    }

    if (targetCard) {
      setTimeout(() => {
        // Scroll dentro del contenedor scrolleable, no en el body
        const scrollArea = document.querySelector(".grid-scroll-area");
        if (scrollArea) {
          const cardTop =
            targetCard!.offsetTop -
            scrollArea.getBoundingClientRect().top +
            scrollArea.scrollTop -
            24;
          scrollArea.scrollTo({ top: cardTop, behavior: "smooth" });
        } else {
          targetCard!.scrollIntoView({ behavior: "smooth", block: "center" });
        }

        targetCard!.style.transition =
          "box-shadow 0.5s ease-in-out, transform 0.5s ease";
        targetCard!.style.boxShadow =
          "0 0 0 6px var(--color-mex-rosa, #e10098)";
        targetCard!.style.transform = "scale(1.02)";

        setTimeout(() => {
          targetCard!.style.boxShadow = "";
          targetCard!.style.transform = "";
        }, 2500);
      }, 300);
    }
  });
</script>

