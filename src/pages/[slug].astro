---
import Layout from '../layouts/Layout.astro';
import Divider from '../components/Divider.astro';
import BusinessCard from '../components/BusinessCard.astro';
import cholulaData from '../data/cholula.json';

export async function getStaticPaths() {
  // Mapeamos los slugs de la URL a las categorías del JSON
  return [
    {
      params: { slug: 'donde-hospedarse' },
      props: {
        title: 'DÓNDE HOSPEDARSE',
        color: 'var(--color-primary)',
        data: cholulaData.hoteles,
      },
    },
    {
      params: { slug: 'donde-comer' },
      props: {
        title: 'DÓNDE COMER',
        color: 'var(--color-accent)',
        data: cholulaData.restaurantes,
      },
    },
    {
      params: { slug: 'que-hacer' },
      props: {
        title: 'QUÉ HACER',
        color: 'var(--color-secondary)',
        data: cholulaData.queHacer,
      },
    },
    {
      params: { slug: 'guias-turisticos' },
      props: {
        title: 'GUÍAS TURÍSTICOS',
        color: '#22c55e',
        data: cholulaData.guiasTuristicos,
      },
    },
  ];
}

const { title, color, data } = Astro.props;

// Imagen de reserva si el item no tiene galería propia
const FALLBACK_IMG = "https://images.unsplash.com/photo-1605335191599-4458d98e1690?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80";
---


<Layout title={title}>
  <!-- Hero — Video cover (mismo que index) -->
  <section class="hero" id="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="/salida.avif" type="video/av1" />
      <source src="/video.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>
  </section>

  <section class="section-categoria">
    <div class="container">
      <h2 class="section-label" style={`--section-color: ${color};`}>{title}</h2>
      <Divider />
      <div class="business-grid">
        {data.map((item: any, index: number) => (
          <BusinessCard
            id={`item-${index}`}
            title={item.nombre}
            images={(item.imagenes && item.imagenes.length > 0) ? item.imagenes : [FALLBACK_IMG]}
            address={item.direccion || undefined}
            phone={item.telefono || undefined}
            instagram={item.social?.instagram || undefined}
            facebook={item.social?.facebook || undefined}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Al cargar la página, verificamos si hay un id en los query parameters
  document.addEventListener("DOMContentLoaded", () => {
    const params = new URLSearchParams(window.location.search);
    const id = params.get("id");
    
    if (id !== null) {
      // Retrasamos un poco la búsqueda para asegurar que el grid y los componentes React estén renderizados
      setTimeout(() => {
        const targetCard = document.getElementById(`item-${id}`);
        if (targetCard) {
          // Scroll suave hasta la tarjeta, centrándola en la pantalla
          targetCard.scrollIntoView({ behavior: "smooth", block: "center" });
          
          // Opcional: Destacamos la tarjeta temporalmente
          targetCard.style.transition = "box-shadow 0.5s ease-in-out, transform 0.5s ease";
          targetCard.style.boxShadow = "0 0 0 6px var(--color-mex-rosa, #e10098)";
          targetCard.style.transform = "scale(1.02)";
          
          setTimeout(() => {
            targetCard.style.boxShadow = "";
            targetCard.style.transform = "";
          }, 2500);
        }
      }, 300);
    }
  });
</script>

<style>
  /* ── Hero (idéntico al de index.astro) ── */
  .hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    overflow: hidden;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.15) 60%,
      rgba(0, 0, 0, 0.6) 100%
    );
    pointer-events: none;
  }

  /* ── Sección de tarjetas ── */
  .section-categoria {
    padding: 3rem 0 6rem;
    background-color: #f9f9f9;
    min-height: 50vh;
  }
  .section-label {
    color: var(--section-color, #555);
    text-align: center;
    font-family: "Roboto", sans-serif;
    font-size: clamp(1.4rem, 2vw, 2rem);
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 0.5rem 0;
  }
  .business-grid {
    display: grid;
    grid-template-columns: repeat(3, 500px);
    gap: 2rem;
    justify-content: center;
    margin: 2rem auto 0;
    padding: 0 4rem;
    max-width: 1600px;
  }

  @media (max-width: 768px) {
    .section-label {
      font-size: 1.4rem;
    }
    .section-categoria {
      overflow-x: hidden;
    }
    .business-grid {
      grid-template-columns: 1fr;
      padding: 0 4rem;
    }
  }
    }
  }
</style>

