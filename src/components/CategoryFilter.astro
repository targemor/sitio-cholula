---
export interface Props {
  options: string[];
}

const { options } = Astro.props;
---

<div class="category-filter-wrapper">
  <div class="custom-dropdown" id="category-dropdown">
    <div class="dropdown-header" id="dropdown-header">
      <span class="dropdown-title" id="dropdown-title"
        >Todas las categorías</span
      >
      <svg
        class="dropdown-arrow"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>

    <div class="dropdown-content" id="dropdown-content">
      {
        options.map((opt) => (
          <label class="dropdown-item">
            <input type="checkbox" value={opt} class="category-checkbox" />
            <div class="checkbox-custom">
              <svg
                viewBox="0 0 24 24"
                class="check-icon"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <span class="dropdown-label">{opt}</span>
          </label>
        ))
      }
    </div>
  </div>
</div>

<style>
  .category-filter-wrapper {
    display: flex;
    justify-content: flex-start;
    position: relative;
    z-index: 50;
  }

  .custom-dropdown {
    width: 100%;
    max-width: 320px;
    position: relative;
  }

  .dropdown-header {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.85rem 1.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .dropdown-header:hover {
    border-color: var(--color-accent, #ff4e50);
    box-shadow: 0 6px 12px -2px rgba(0, 0, 0, 0.08);
  }

  .custom-dropdown.open .dropdown-header {
    border-color: var(--color-accent, #ff4e50);
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .dropdown-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: #334155;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dropdown-arrow {
    color: #64748b;
    transition: transform 0.3s ease;
  }

  .custom-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-content {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-top: none;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    max-height: 280px;
    overflow-y: auto;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .custom-dropdown.open .dropdown-content {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    padding: 0.8rem 1.2rem;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .dropdown-item:hover {
    background-color: #f8fafc;
  }

  /* Custom Checkbox */
  .category-checkbox {
    display: none;
  }

  .checkbox-custom {
    width: 20px;
    height: 20px;
    border: 2px solid #cbd5e1;
    border-radius: 6px;
    margin-right: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    background: transparent;
  }

  .category-checkbox:checked + .checkbox-custom {
    background: var(--color-accent, #ff4e50);
    border-color: var(--color-accent, #ff4e50);
  }

  .check-icon {
    width: 14px;
    height: 14px;
    color: white;
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .category-checkbox:checked + .checkbox-custom .check-icon {
    opacity: 1;
    transform: scale(1);
  }

  .dropdown-label {
    font-size: 0.95rem;
    color: #475569;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .category-filter-wrapper {
      justify-content: center;
    }
  }
</style>

<script>
  function setupDropdown() {
    const dropdown = document.getElementById("category-dropdown");
    const header = document.getElementById("dropdown-header");
    const title = document.getElementById("dropdown-title");
    const checkboxes = document.querySelectorAll(".category-checkbox");
    const cards = document.querySelectorAll(".business-card");

    if (!dropdown || !header || !title) return;

    // Toggle dropdown
    header.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("open");
    });

    // Close when clicking outside
    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target)) {
        dropdown.classList.remove("open");
      }
    });

    // Handle checkbox change
    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        // Obtenemos todos los seleccionados
        const checkedValues = Array.from(
          document.querySelectorAll(".category-checkbox:checked"),
        ).map((cb) => cb.value);

        // Actualizar texto del header
        if (checkedValues.length === 0) {
          title.textContent = "Todas las categorías";
        } else if (checkedValues.length === 1) {
          title.textContent = checkedValues[0];
        } else {
          title.textContent = `${checkedValues.length} categorías seleccionadas`;
        }

        // Mostrar/ocultar tarjetas
        cards.forEach((card) => {
          const cardEl = card;
          const cardClasificacion = cardEl.dataset.clasificacion;

          if (checkedValues.length === 0) {
            // Mostrar todas si no hay filtros
            cardEl.style.display = "";
          } else {
            // Mostrar solo si su clasificación está en los filtros
            cardEl.style.display =
              cardClasificacion && checkedValues.includes(cardClasificacion)
                ? ""
                : "none";
          }
        });
      });
    });
  }

  setupDropdown();
  document.addEventListener("astro:page-load", setupDropdown);
</script>
