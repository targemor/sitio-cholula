---
import "./CategoryFilter.css";

export interface Props {
  options: string[];
}

const { options } = Astro.props;
---

<div class="category-filter-wrapper">
  <div class="custom-dropdown" id="category-dropdown">
    <div class="dropdown-header" id="dropdown-header">
      <span class="dropdown-title" id="dropdown-title"
        >Todas las categorías</span
      >
      <svg
        class="dropdown-arrow"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>

    <div class="dropdown-content" id="dropdown-content">
      {
        options.map((opt) => (
          <label class="dropdown-item">
            <input type="checkbox" value={opt} class="category-checkbox" />
            <div class="checkbox-custom">
              <svg
                viewBox="0 0 24 24"
                class="check-icon"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <span class="dropdown-label">{opt}</span>
          </label>
        ))
      }
    </div>
  </div>
</div>

<script>
  function setupDropdown() {
    const dropdown = document.getElementById("category-dropdown");
    const header = document.getElementById("dropdown-header");
    const title = document.getElementById("dropdown-title");
    const checkboxes = document.querySelectorAll(".category-checkbox");
    const cards = document.querySelectorAll(".business-card");

    if (!dropdown || !header || !title) return;

    // Toggle dropdown
    header.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("open");
    });

    // Close when clicking outside
    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target)) {
        dropdown.classList.remove("open");
      }
    });

    // Handle checkbox change
    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        // Obtenemos todos los seleccionados
        const checkedValues = Array.from(
          document.querySelectorAll(".category-checkbox:checked"),
        ).map((cb) => cb.value);

        // Actualizar texto del header
        if (checkedValues.length === 0) {
          title.textContent = "Todas las categorías";
        } else if (checkedValues.length === 1) {
          title.textContent = checkedValues[0];
        } else {
          title.textContent = `${checkedValues.length} categorías seleccionadas`;
        }

        // Mostrar/ocultar tarjetas
        cards.forEach((card) => {
          const cardEl = card;
          const cardClasificacion = cardEl.dataset.clasificacion;

          if (checkedValues.length === 0) {
            // Mostrar todas si no hay filtros
            cardEl.style.display = "";
          } else {
            // Mostrar solo si su clasificación está en los filtros
            cardEl.style.display =
              cardClasificacion && checkedValues.includes(cardClasificacion)
                ? ""
                : "none";
          }
        });
      });
    });
  }

  setupDropdown();
  document.addEventListener("astro:page-load", setupDropdown);
</script>
