---
export interface ItineraryElement {
  icono?: string;
  titulo?: string;
  descripcion?: string;
  meta?: string;
  chat?: string;
  texto?: string;
}

export interface DayItinerary {
  titulo: string;
  elementos: (string | ItineraryElement)[];
}

export interface DaytripRow {
  emoji?: string;
  nombre: string;
  meta?: string;
}

export interface Daytrip {
  titulo: string;
  elementos: DaytripRow[];
  footer?: string;
}

export interface Tip {
  titulo: string;
  contenido?: string;
  elementos?: string[];
}

export interface ItineraryProps {
  id: string;
  tabLabel?: string;
  mobileTabLabel?: string;
  titulo: string;
  subtitulo?: string;
  descripcion?: string;
  heroKicker?: string;
  heroBgClass?: string;
  heroImage?: string;
  heroCredit?: string;
  heroTitle?: string;
  heroSub?: string;
  elementos?: (string | ItineraryElement)[];
  dias?: DayItinerary[];
  daytrip?: Daytrip;
  consejos?: Tip[];
}

interface Props {
  itinerario: ItineraryProps;
}

const { itinerario } = Astro.props;
---

<div class="itinerario-container">
  {/* HERO */}
  <div class="itin-hero">
    <div class="itin-hero-bg" style={`background-image:url('${itinerario.heroImage || ''}');`}></div>
    <div class="itin-hero-overlay"></div>
    <div class="itin-hero-text">
      {itinerario.heroKicker && <div class="itin-hero-kicker">{itinerario.heroKicker}</div>}
      <div class="itin-hero-title">{itinerario.heroTitle || itinerario.titulo}</div>
      {itinerario.heroSub && <div class="itin-hero-sub">{itinerario.heroSub}</div>}
    </div>
    {itinerario.heroCredit && <div class="photo-credit">{itinerario.heroCredit}</div>}
  </div>

  <div class="itin-body">
    {itinerario.descripcion && <p class="desc">{itinerario.descripcion}</p>}

    {
      itinerario.elementos &&
        itinerario.elementos.map((item) => {
          const isStr = typeof item === 'string';
          const i = isStr ? { titulo: item } as ItineraryElement : item as ItineraryElement;
          return (
            <div class="stop">
              <div class="stop-icon">{i.icono || "📍"}</div>
              <div class="stop-content">
                <div class="stop-name">{i.titulo}</div>
                {i.descripcion && <div class="stop-desc">{i.descripcion}</div>}
                {i.meta && <div class="stop-meta">{i.meta}</div>}
                {i.chat && <div class="stop-chat">{i.chat}</div>}
              </div>
            </div>
          );
        })
    }

    {
      itinerario.dias &&
        itinerario.dias.map((dia) => (
          <div class="timeline-day">
            <div class="day-label">{dia.titulo}</div>
            {dia.elementos.map((item) => {
              const isStr = typeof item === 'string';
              const i = isStr ? { titulo: item } as ItineraryElement : item as ItineraryElement;
              return (
                <div class="stop">
                  <div class="stop-icon">{i.icono || "📍"}</div>
                  <div class="stop-content">
                    <div class="stop-name">{i.titulo}</div>
                    {i.descripcion && <div class="stop-desc">{i.descripcion}</div>}
                    {i.meta && <div class="stop-meta">{i.meta}</div>}
                    {i.chat && <div class="stop-chat">{i.chat}</div>}
                  </div>
                </div>
              );
            })}
          </div>
        ))
    }

    {
      itinerario.daytrip && (
        <div class="daytrip">
          <div class="daytrip-title">{itinerario.daytrip.titulo}</div>
          {itinerario.daytrip.elementos.map((row) => (
            <div class="daytrip-row">
              <div class="daytrip-emoji">{row.emoji}</div>
              <div>
                <div class="daytrip-name">{row.nombre}</div>
                {row.meta && <div class="daytrip-meta">{row.meta}</div>}
              </div>
            </div>
          ))}
          {itinerario.daytrip.footer && <div class="daytrip-footer">{itinerario.daytrip.footer}</div>}
        </div>
      )
    }

    {
      itinerario.consejos && itinerario.consejos.length > 0 && (
        <>
          {itinerario.consejos.map((consejo) => (
            <div class="tip-box">
              <div class="tip-title">{consejo.titulo}</div>
              {consejo.contenido && <p style="font-size: 12px; color: #6B5A20; margin-bottom: 8px;">{consejo.contenido}</p>}
              {consejo.elementos && (
                <ul class="tip-list">
                  {consejo.elementos.map((el) => (
                    <li>{el}</li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </>
      )
    }
  </div>
</div>

<style>
  .itinerario-container {
    width: 100%;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 6px 20px rgba(30,25,15,0.07);
    font-family: Arial, Helvetica, sans-serif;
  }

  /* HERO */
  .itin-hero {
    width: 100%;
    height: 240px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .itin-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.85;
  }
  .itin-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 25%, rgba(0,0,0,0.62) 100%);
  }
  .bg1 { background: linear-gradient(160deg, #f5b56a 0%, #e8935a 30%, #b06a4a 55%, #5a4a52 80%, #3a3542 100%); }
  .bg2 { background: linear-gradient(160deg, #3a3542 0%, #5a4a52 30%, #b06a4a 55%, #e8935a 80%, #f5b56a 100%); }
  .bg3 { background: linear-gradient(160deg, #3f8f8a 0%, #085041 45%, #2B2B29 100%); }
  .bg4 { background: linear-gradient(160deg, #A0413A 0%, #c9a227 45%, #3f8f8a 100%); }
  
  .itin-hero-text {
    position: relative;
    z-index: 2;
    padding: 22px 36px;
    width: 100%;
  }
  .itin-hero-kicker {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    color: #F2C230;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .itin-hero-title {
    font-size: 24px;
    font-weight: bold;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 4px;
  }
  .itin-hero-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
  }
  .photo-credit {
    position: absolute;
    bottom: 10px;
    right: 16px;
    font-size: 10px;
    color: rgba(255,255,255,0.55);
    z-index: 2;
  }

  /* BODY */
  .itin-body {
    padding: 28px 44px 32px;
  }
  .desc {
    font-size: 14px;
    color: #6B6560;
    line-height: 1.5;
    margin-bottom: 20px;
  }
  .day-label {
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #A0413A;
    margin: 22px 0 12px;
  }

  /* STOP */
  .stop {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid #F5F1E8;
  }
  .stop:last-child { border-bottom: none; }
  .stop-icon {
    font-size: 18px;
    flex-shrink: 0;
    width: 28px;
    text-align: center;
    padding-top: 2px;
  }
  .stop-content { flex: 1; }
  .stop-name {
    font-size: 14px;
    font-weight: bold;
    color: #2B2B29;
    margin-bottom: 2px;
  }
  .stop-desc {
    font-size: 12px;
    color: #6B6560;
    line-height: 1.4;
    margin-bottom: 3px;
  }
  .stop-meta {
    font-size: 11px;
    color: #A8A39A;
  }
  .stop-chat {
    font-size: 11.5px;
    color: #A0413A;
    font-weight: bold;
    margin-top: 3px;
  }

  /* DAYTRIP */
  .daytrip { background: #2B2B29; border-radius: 12px; padding: 22px 26px; margin: 20px 0 0; }
  .daytrip-title { font-size: 16px; font-weight: bold; color: #F2C230; margin-bottom: 14px; }
  .daytrip-row { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
  .daytrip-emoji { font-size: 22px; }
  .daytrip-name { font-size: 14px; font-weight: bold; color: #fff; }
  .daytrip-meta { font-size: 12px; color: rgba(255,255,255,0.55); }
  .daytrip-footer { font-size: 12px; color: rgba(255,255,255,0.75); margin-top: 14px; font-style: italic; }

  /* TIP BOX */
  .tip-box {
    background: #FBF1D8;
    border-radius: 12px;
    padding: 14px 18px;
    margin-top: 20px;
  }
  .tip-title {
    font-size: 10px;
    font-weight: bold;
    color: #8A6910;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .tip-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tip-list li {
    font-size: 12px;
    color: #6B5A20;
    padding: 2px 0;
  }
  
  @media (max-width: 768px) {
    .itinerario-container {
      border-radius: 0;
    }
    .itin-hero {
      height: 200px;
    }
    .itin-hero-text {
      padding: 16px 20px;
    }
    .itin-hero-title {
      font-size: 20px;
    }
    .itin-body {
      padding: 20px;
    }
  }
</style>
