---
import SwiperGallery from "./SwiperGallery.astro";
import "./BusinessCard.css";

export interface Props {
  id?: string;
  title: string;
  images: string[];
  instagram?: string;
  facebook?: string;
  address?: string;
  phone?: string;
}

const {
  id,
  title,
  images,
  instagram,
  facebook,
  address,
  phone,
} = Astro.props;

const swiperId = `business-swiper-${id || Math.random().toString(36).substr(2, 9)}`;
const igGradId = `ig-grad-card-${swiperId}`;
---

<div class="business-card" id={id}>
  <div class="business-card-slider">
    <SwiperGallery id={swiperId} items={images.map(img => ({ img }))} className="business-swiper" />
  </div>

  <div class="business-card-content">
    <h3 class="business-card-title">{title}</h3>
    <ul class="business-card-info">
      {instagram && (
        <li>
          <a
            href={instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <div class="icon">
              <svg
                viewBox="0 0 448 512"
                width="20"
                height="20"
                aria-hidden="true"
              >
                <defs>
                  <linearGradient
                    id={igGradId}
                    x1="0%"
                    y1="100%"
                    x2="100%"
                    y2="0%"
                  >
                    <stop offset="0%" stop-color="#fdf497" />
                    <stop offset="5%" stop-color="#fdf497" />
                    <stop offset="45%" stop-color="#fd5949" />
                    <stop offset="60%" stop-color="#d6249f" />
                    <stop offset="90%" stop-color="#285AEB" />
                  </linearGradient>
                </defs>
                <path
                  fill={`url(#${igGradId})`}
                  d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"
                />
              </svg>
            </div>
            <span>{title}</span>
          </a>
        </li>
      )}
      {facebook && (
        <li>
          <a
            href={facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            <div class="icon">
              <svg
                viewBox="0 0 448 512"
                width="20"
                height="20"
                aria-hidden="true"
                class="icon--facebook"
              >
                <path
                  fill="currentColor"
                  d="M400 32H48A48 48 0 0 0 0 80v352a48 48 0 0 0 48 48h137.25V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.27c-30.81 0-40.42 19.12-40.42 38.73V256h68.78l-11 71.69h-57.78V480H400a48 48 0 0 0 48-48V80a48 48 0 0 0-48-48z"
                />
              </svg>
            </div>
            <span>{title}</span>
          </a>
        </li>
      )}
      {address && (
        <li>
          <div class="icon">
            <svg
              viewBox="0 0 384 512"
              width="18"
              height="18"
              aria-hidden="true"
              class="icon--location"
            >
              <path
                fill="currentColor"
                d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"
              />
            </svg>
          </div>
          <span>{address}</span>
        </li>
      )}
    </ul>

    <div class="business-card-phone">
      <strong>Teléfono:</strong> {phone ?? "N/A"}
    </div>
  </div>
</div>

<style>
  :global(.business-swiper .swiper-slide-img) {
    height: 560px !important;
    object-fit: cover !important;
  }
</style>
