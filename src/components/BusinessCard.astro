---
export interface Props {
  title: string;
  images: string[];
  instagram?: string;
  facebook?: string;
  address?: string;
  phone?: string;
}

const { title, images, instagram, facebook, address, phone } = Astro.props;
---

<div class="business-card">
  <div class="business-card-slider">
    <div class="swiper js-business-swiper">
      <div class="swiper-wrapper">
        {images.map(img => (
          <div class="swiper-slide">
            <img src={img} alt={title} loading="lazy" />
          </div>
        ))}
      </div>
      <!-- Arrows -->
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <!-- Pagination -->
      <div class="swiper-pagination"></div>
    </div>
  </div>

  <div class="business-card-content">
    <h3 class="business-card-title">{title}</h3>
    <ul class="business-card-info">
      {instagram && (
        <li>
          <div class="icon">
            <svg viewBox="0 0 448 512" width="20" height="20" aria-hidden="true">
              <defs>
                <linearGradient id="ig-grad-card" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#fdf497" />
                  <stop offset="5%" stop-color="#fdf497" />
                  <stop offset="45%" stop-color="#fd5949" />
                  <stop offset="60%" stop-color="#d6249f" />
                  <stop offset="90%" stop-color="#285AEB" />
                </linearGradient>
              </defs>
              <path fill="url(#ig-grad-card)" d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
            </svg>
          </div>
          <span>{instagram}</span>
        </li>
      )}
      {facebook && (
        <li>
          <div class="icon">
            <svg viewBox="0 0 448 512" width="20" height="20" aria-hidden="true" class="icon--facebook">
              <path fill="currentColor" d="M400 32H48A48 48 0 0 0 0 80v352a48 48 0 0 0 48 48h137.25V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.27c-30.81 0-40.42 19.12-40.42 38.73V256h68.78l-11 71.69h-57.78V480H400a48 48 0 0 0 48-48V80a48 48 0 0 0-48-48z"></path>
            </svg>
          </div>
          <span>{facebook}</span>
        </li>
      )}
      {address && (
        <li>
          <div class="icon">
            <svg viewBox="0 0 384 512" width="18" height="18" aria-hidden="true" class="icon--location">
              <path fill="currentColor" d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"></path>
            </svg>
          </div>
          <span>{address}</span>
        </li>
      )}
    </ul>
    
    <div class="business-card-phone">
      <strong>Teléfono:</strong> {phone ? phone : ""}
    </div>
  </div>
</div>

<style>
  .business-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-width: 450px; /* Optional, depends on grid */
    font-family: "Roboto", sans-serif;
  }
  
  .business-card-slider {
    width: 100%;
    position: relative;
    padding-bottom: 2rem; /* Space for pagination dots */
  }

  .js-business-swiper {
    width: 100%;
    height: 100%;
    position: static; /* Let pagination escape the container */
  }

  .swiper-slide img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  /* Navigation Arrows */
  .swiper-button-next,
  .swiper-button-prev {
    color: #fff !important;
    width: 32px;
    height: 32px;
    margin-top: -32px; /* Offset to center vertically relative to image */
  }
  .swiper-button-next::after,
  .swiper-button-prev::after {
    font-size: 1.5rem !important;
  }

  /* Pagination Dots */
  .swiper-pagination {
    bottom: 5px !important; /* Place it in the padding area */
  }
  .business-card-slider :global(.swiper-pagination-bullet) {
    background: #ccc;
    opacity: 1;
    width: 6px;
    height: 6px;
    margin: 0 4px !important;
  }
  .business-card-slider :global(.swiper-pagination-bullet-active) {
    background: #000;
  }

  .business-card-content {
    padding: 1rem 0;
    text-align: left;
  }

  .business-card-title {
    color: #c15c54;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
  }

  .business-card-info {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .business-card-info li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: #4a4a4a;
  }

  .business-card-info .icon {
    width: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .business-card-phone {
    font-size: 0.95rem;
    color: #4a4a4a;
    display: flex;
    gap: 0.25rem;
  }

  .business-card-phone strong {
    color: #c15c54;
    font-weight: 700;
  }

  .icon--facebook {
    color: #1877f2;
  }

  .icon--location {
    color: #000;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  // Initialize swipers on client load
  document.addEventListener('DOMContentLoaded', () => {
    const swipers = document.querySelectorAll('.js-business-swiper');
    swipers.forEach(el => {
      new Swiper(el as HTMLElement, {
        modules: [Navigation, Pagination],
        slidesPerView: 1,
        loop: true,
        navigation: {
          nextEl: el.querySelector('.swiper-button-next') as HTMLElement,
          prevEl: el.querySelector('.swiper-button-prev') as HTMLElement,
        },
        pagination: {
          el: el.querySelector('.swiper-pagination') as HTMLElement,
          clickable: true,
        },
      });
    });
  });
</script>
