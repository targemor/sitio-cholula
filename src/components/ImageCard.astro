---
import "./ImageCard.css";

export interface Props {
  href: string;
  img: string;
  label: string;
  color: string;
  target?: string;
}

const { href, img, label, color, target = "_self" } = Astro.props;
---

<a
  href={href}
  target={target}
  class="image-card"
  style={`--bar-color: ${color}`}
>
  <img src={img} alt={label} class="image-card-img" loading="lazy" />
  <div class="image-card-bar">
    <span>{label}</span>
  </div>
</a>
