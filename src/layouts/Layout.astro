---
import "../styles/global-opt.css";
import Header from "../components/Header";
import BottomNav from "../components/BottomNav";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Descubre la magia de Cholula, el corazón de México.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Visit Cholula</title>

		<!-- Google Fonts: Roboto -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Header client:load />

		<main>
			<slot />
		</main>

		<footer class="main-footer">
			<div class="footer-container">
				<div class="footer-col">
					<strong>Dirección de Turismo</strong>
					<p>Calle 4 Oriente 1 Centro, San Pedro Cholula.</p>
				</div>
				<div class="footer-col">
					<strong>Teléfonos:</strong>
					<p>(222) 2 47 33 93, (222) 7 77 29 00<br />Ext. 2912</p>
				</div>
			</div>
		</footer>

		<!-- WhatsApp flotante -->
		<a
			href="https://wa.me/2221029059"
			class="whatsapp-fab"
			id="whatsapp-fab"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Contactar por WhatsApp"
		>
			<svg
				viewBox="0 0 448 512"
				width="32"
				height="32"
				aria-hidden="true"
			>
				<path
					fill="white"
					d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-23.1-115-65-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-2.1-3.6 .1-5.5 1.8-7.3 1.6-1.6 3.7-4.2 5.5-6.3 1.8-2.1 2.4-3.7 3.6-6.2 1.2-2.5 .6-4.7-.3-6.2-1.9-3.4-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
				></path>
			</svg>
		</a>

		<BottomNav client:load />
	</body>
</html>

<style is:global>
	:root {
		--color-primary: #c15c54;
		--color-secondary: #4a8fa1;
		--color-accent: #e5a93c;
	}

	body,
	h1,
	h2,
	h3,
	h4,
	h5,
	h6,
	p,
	a,
	span,
	div,
	li,
	button,
	input,
	textarea {
		font-family: "Roboto", sans-serif !important;
	}
</style>

<style>
	main {
		min-height: 100vh;
		/* No padding-top: header is transparent and floats over the video */
	}

	.main-footer {
		background-color: var(--color-primary);
		color: #ffffff;
		padding: 3rem 1rem;
		position: relative;
		margin-top: 0;
	}
	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: flex-start;
		gap: 6rem;
		padding-left: 2rem;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: 0.95rem;
	}
	.footer-col strong {
		font-weight: 700;
	}
	.footer-col p {
		margin: 0;
		font-weight: 400;
		line-height: 1.5;
	}
	#scrollToTopBtn {
		position: absolute;
		right: 20px;
		bottom: 20px;
		background-color: #007bff;
		color: #fff;
		border: none;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		border-radius: 4px;
	}
	#scrollToTopBtn:hover {
		background-color: #0056b3;
	}

	@media (max-width: 768px) {
		.main-nav {
			display: none; /* Mobile menu needed */
		}

		.footer-container {
			flex-direction: column;
			gap: 2rem;
			padding-left: 1rem;
		}
	}

	/* ══════════════════════════
	   WHATSAPP FAB
	   ══════════════════════════ */
	.whatsapp-fab {
		position: fixed;
		bottom: 24px;
		right: 24px;
		z-index: 999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #4fce5d, #25d366, #128c7e);
		background-size: 200% 200%;
		animation: whatsappGradient 4s ease infinite;
		color: #fff;
		text-decoration: none;
		padding: 16px;
		border-radius: 50%;
		box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}
	.whatsapp-fab:hover {
		transform: translateY(-4px) scale(1.08);
		box-shadow: 0 10px 28px rgba(37, 211, 102, 0.7);
	}

	@media (max-width: 768px) {
		.whatsapp-fab {
			bottom: calc(
				96px + env(safe-area-inset-bottom, 0px)
			); /* Evita chocar con el BottomNav de forma segura */
			right: 16px;
		}
	}

	@keyframes whatsappGradient {
		0% {
			background-position: 0% 50%;
		}
		50% {
			background-position: 100% 50%;
		}
		100% {
			background-position: 0% 50%;
		}
	}
</style>
