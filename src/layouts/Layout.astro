---
import "../styles/global-opt.css";
import Header from "../components/Header";
import BottomNav from "../components/BottomNav";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Descubre la magia de Cholula, el corazón de México.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Visit Cholula</title>

		<!-- Google Fonts: Roboto -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<Header client:load />

		<main>
			<slot />
		</main>

		<footer class="main-footer">
			<div class="footer-divider"></div>
			<div class="footer-container">
				<!-- Columna izquierda: info del municipio -->
				<div class="footer-col footer-info">
					<strong class="footer-section-title"
						>Dirección de Turismo y Contacto</strong
					>
					<p>Calle 4 Oriente 1 Centro, San Pedro Cholula.</p>
					<p>(222) 2 47 33 93, (222) 7 77 29 00, Ext. 2912</p>
				</div>

				<!-- Separador vertical -->
				<div class="footer-vline"></div>

				<!-- Centro: logo imagen -->
				<div class="footer-col footer-logo-center">
					<img
						src="https://visitcholula.mx/wp-content/uploads/2026/04/Untitled-design-3-Photoroom-e1775961036414-1024x888.png"
						alt="Visit Cholula"
						class="footer-logo-img"
					/>
				</div>

				<!-- Separador vertical -->
				<div class="footer-vline"></div>

				<!-- Columna derecha: redes sociales -->
				<div class="footer-col footer-social">
					<strong class="footer-section-title"
						>Síguenos en nuestras redes sociales</strong
					>
					<div class="social-icons">
						<!-- Facebook -->
						<a
							href="https://www.facebook.com/TurismoCholula"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Facebook"
							class="social-icon social-facebook"
						>
							<svg
								viewBox="0 0 24 24"
								width="28"
								height="28"
								fill="currentColor"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
								></path>
							</svg>
						</a>
						<!-- TikTok -->
						<a
							href="https://www.tiktok.com/@turismocholula"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="TikTok"
							class="social-icon social-tiktok"
						>
							<svg
								viewBox="0 0 24 24"
								width="28"
								height="28"
								fill="currentColor"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"
								></path>
							</svg>
						</a>
						<!-- Instagram -->
						<a
							href="https://www.instagram.com/turismocholula"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Instagram"
							class="social-icon social-instagram"
						>
							<svg
								viewBox="0 0 24 24"
								width="28"
								height="28"
								fill="currentColor"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
								></path>
							</svg>
						</a>
					</div>
					<!-- Compartir -->
					<div class="footer-share">
						<p class="footer-share-title">
							Comparte nuestra página en:
						</p>
						<div class="footer-share-buttons">
							<a
								href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fvisitcholula.mx"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Compartir en Facebook"
								class="footer-share-btn footer-share-btn--facebook"
							>
								<svg
									viewBox="0 0 448 512"
									width="16"
									height="16"
									><path
										fill="currentColor"
										d="M400 32H48A48 48 0 0 0 0 80v352a48 48 0 0 0 48 48h137.25V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.27c-30.81 0-40.42 19.12-40.42 38.73V256h68.78l-11 71.69h-57.78V480H400a48 48 0 0 0 48-48V80a48 48 0 0 0-48-48z"
									></path></svg
								>
							</a>
							<a
								href="mailto:?subject=Visita%20Cholula%20Pueblo%20M%C3%A1gico&body=Te%20comparto%20la%20gu%C3%ADa%20tur%C3%ADstica%20de%20Cholula%3A%20https%3A%2F%2Fvisitcholula.mx"
								aria-label="Compartir por Email"
								class="footer-share-btn footer-share-btn--email"
							>
								<svg
									viewBox="0 0 512 512"
									width="16"
									height="16"
									><path
										fill="currentColor"
										d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"
									></path></svg
								>
							</a>
							<a
								href="https://api.whatsapp.com/send?text=Te%20comparto%20la%20gu%C3%ADa%20tur%C3%ADstica%20de%20Cholula%20%F0%9F%8F%9B%EF%B8%8F%20https%3A%2F%2Fvisitcholula.mx"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Compartir en WhatsApp"
								class="footer-share-btn footer-share-btn--whatsapp"
							>
								<svg
									viewBox="0 0 448 512"
									width="16"
									height="16"
									><path
										fill="currentColor"
										d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-23.1-115-65-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-2.1-3.6 .1-5.5 1.8-7.3 1.6-1.6 3.7-4.2 5.5-6.3 1.8-2.1 2.4-3.7 3.6-6.2 1.2-2.5 .6-4.7-.3-6.2-1.9-3.4-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
									></path></svg
								>
							</a>
							<a
								href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fvisitcholula.mx"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Compartir en LinkedIn"
								class="footer-share-btn footer-share-btn--linkedin"
							>
								<svg
									viewBox="0 0 448 512"
									width="16"
									height="16"
									><path
										fill="currentColor"
										d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.88-48.3 94 0 111.28 61.9 111.28 142.3V448z"
									></path></svg
								>
							</a>
							<a
								href="https://twitter.com/intent/tweet?url=https%3A%2F%2Fvisitcholula.mx&text=Conoce%20Cholula%2C%20Pueblo%20M%C3%A1gico%20%F0%9F%8F%9B%EF%B8%8F"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Compartir en X"
								class="footer-share-btn footer-share-btn--x"
							>
								<svg
									viewBox="0 0 512 512"
									width="16"
									height="16"
									><path
										fill="currentColor"
										d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"
									></path></svg
								>
							</a>
						</div>
					</div>
				</div>
			</div>
			<!-- Aviso de privacidad -->
			<a href="/aviso-de-privacidad" class="footer-privacy-link"
				>Aviso de privacidad</a
			>
		</footer>

		<!-- WhatsApp flotante -->
		<a
			href="https://wa.me/2221029059"
			class="whatsapp-fab"
			id="whatsapp-fab"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Contactar por WhatsApp"
		>
			<svg
				viewBox="0 0 448 512"
				width="32"
				height="32"
				aria-hidden="true"
			>
				<path
					fill="white"
					d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-23.1-115-65-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-2.1-3.6 .1-5.5 1.8-7.3 1.6-1.6 3.7-4.2 5.5-6.3 1.8-2.1 2.4-3.7 3.6-6.2 1.2-2.5 .6-4.7-.3-6.2-1.9-3.4-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
				></path>
			</svg>
		</a>

		<BottomNav client:load />
	</body>
</html>

<style is:global>
	html,
	body,
	main {
		overflow-x: visible !important;
		overflow-y: visible !important;
	}
	:root {
		--color-primary: #c15c54;
		--color-secondary: #4a8fa1;
		--color-accent: #e5a93c;
	}

	body,
	h1,
	h2,
	h3,
	h4,
	h5,
	h6,
	p,
	a,
	span,
	div,
	li,
	button,
	input,
	textarea {
		font-family: "Roboto", sans-serif !important;
	}
</style>

<style>
	main {
		min-height: 100vh;
		/* No padding-top: header is transparent and floats over the video */
	}

	.main-footer {
		background-color: var(--color-primary);
		color: #ffffff;
		padding: 2.5rem 1rem 2.5rem;
		position: relative;
		margin-top: 0;
	}
	.footer-divider {
		max-width: 90%;
		margin: 0 auto 2rem;
		height: 2px;
		background-color: rgba(255, 255, 255, 0.45);
	}
	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		padding: 0 2rem;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: 0.88rem;
	}
	.footer-section-title {
		font-weight: 700;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.4rem;
		display: block;
		text-align: center;
	}
	.footer-col p {
		margin: 0;
		line-height: 1.55;
	}
	.footer-info {
		flex: 0 1 240px;
		text-align: center;
	}
	/* Separadores verticales */
	.footer-vline {
		width: 2px;
		min-height: 100px;
		background-color: rgba(255, 255, 255, 0.35);
	}
	/* Logo central */
	.footer-logo-center {
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
	}
	.footer-logo-img {
		width: 110px;
		height: auto;
		object-fit: contain;
		filter: brightness(0) invert(1);
		opacity: 0.9;
	}
	.footer-social {
		flex: 0 1 220px;
		align-items: center;
	}
	/* Link aviso de privacidad */
	.footer-privacy-link {
		margin-top: 1rem;
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: underline;
		text-underline-offset: 3px;
		transition: color 0.2s ease;
		text-align: center;
		display: block;
	}
	.footer-privacy-link:hover {
		color: #ffffff;
	}
	/* Social icons row */
	.social-icons {
		display: flex;
		gap: 0.85rem;
		align-items: center;
		margin-top: 0.35rem;
	}
	.social-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 46px;
		height: 46px;
		border-radius: 50%;
		transition:
			transform 0.22s ease,
			box-shadow 0.22s ease;
		text-decoration: none;
	}
	.social-icon:hover {
		transform: translateY(-3px) scale(1.1);
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
	}
	/* Facebook – brand blue */
	.social-facebook {
		background-color: #1877f2;
		color: #ffffff;
	}
	/* TikTok – near black with subtle shimmer */
	.social-tiktok {
		background-color: #010101;
		color: #ffffff;
	}
	/* Instagram – brand gradient */
	.social-instagram {
		background: radial-gradient(
			circle at 30% 107%,
			#fdf497 0%,
			#fdf497 5%,
			#fd5949 45%,
			#d6249f 60%,
			#285aeb 90%
		);
		color: #ffffff;
	}
	/* Compartir en footer */
	.footer-share {
		margin-top: 0.8rem;
	}
	.footer-share-title {
		font-weight: 700;
		margin: 1rem;
	}
	.footer-share-buttons {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-top: 1em;
	}
	.footer-share-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 6px;
		color: #fff;
		text-decoration: none;
		transition:
			transform 0.18s ease,
			opacity 0.18s ease;
		opacity: 0.92;
	}
	.footer-share-btn:hover {
		transform: translateY(-2px);
		opacity: 1;
	}
	.footer-share-btn--facebook {
		background: #1877f2;
	}
	.footer-share-btn--email {
		background: #888;
	}
	.footer-share-btn--whatsapp {
		background: #25d366;
	}
	.footer-share-btn--linkedin {
		background: #0077b5;
	}
	.footer-share-btn--x {
		background: #000;
	}

	@media (max-width: 768px) {
		.main-nav {
			display: none; /* Mobile menu needed */
		}

		.footer-container {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 2rem;
			padding: 0 1.25rem;
		}
		.footer-col {
			align-items: center;
			width: 100%;
			flex: auto;
		}
		.footer-vline {
			display: none;
		}
		.footer-logo-center {
			align-self: center;
			width: 100%;
		}
		.footer-logo-img {
			width: 90px;
		}
		.footer-divider {
			margin: 0 1.25rem 1.75rem;
		}
	}

	/* ══════════════════════════
	   WHATSAPP FAB
	   ══════════════════════════ */
	.whatsapp-fab {
		position: fixed;
		bottom: 24px;
		right: 24px;
		z-index: 999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #4fce5d, #25d366, #128c7e);
		background-size: 200% 200%;
		animation: whatsappGradient 4s ease infinite;
		color: #fff;
		text-decoration: none;
		padding: 16px;
		border-radius: 50%;
		box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}
	.whatsapp-fab:hover {
		transform: translateY(-4px) scale(1.08);
